tle":"Bobby \u670d\u52a1\u5668\u533a\u5757\u7f13\u5b58","text":"<p>\u4e3a\u4e86\u4f18\u5316\u5e26\u5bbd\u5360\u7528, \u670d\u52a1\u5668\u8bbe\u7f6e\u7684\u89c6\u8ddd\u504f\u5c0f</p> <p>\u4f60\u53ef\u4ee5\u901a\u8fc7\u5b89\u88c5Bobby\u6765\u7f13\u5b58\u670d\u52a1\u5668\u533a\u5757, \u83b7\u5f97\u66f4\u5927\u89c6\u8ddd</p>"},{"location":"preparation/#distant-horzion","title":"Distant Horzion \u9065\u8fdc\u7684\u5730\u5e73\u7ebf (\u4ec5\u5916\u670d)","text":"<p>\u6211\u4eec\u5728TACS\u5916\u670d\u914d\u7f6e\u4e86\u76f8\u5173\u7684\u63d2\u4ef6/Mod, \u5ba2\u6237\u7aef\u53ea\u9700\u5b89\u88c5\u6b64Mod\u5373\u53ef\u4eab\u53d7\u5230\u8d85\u9ad8\u89c6\u91ce\u5e26\u6765\u7684\u753b\u9762</p> <p>\u8be6\u7ec6\u4fe1\u606f\u53ca\u652f\u6301\u8303\u56f4\u8bf7\u67e5\u770b[\u5916\u670d\u76f8\u5173\u9875\u9762]</p> <p>\u9700\u8981\u624b\u52a8\u914d\u7f6e</p> <p>\u70b9\u51fb\u4e0b\u8f7d\u914d\u7f6e\u6c49\u5316\u6750\u8d28\u5305</p>"},{"location":"preparation/#caramelchat","title":"caramelChat \u8f93\u5165\u6cd5\u51b2\u7a81\u89e3\u51b3","text":"<p>\u9ad8\u7248\u672c\u7684\u8f93\u5165\u6cd5\u51b2\u7a81\u89e3\u51b3\u6a21\u7ec4, \u53ef\u4ee5\u907f\u514d\u4f60<code>aaaaaaaaaaaadssadwwd</code></p>"},{"location":"preparation/#particle-rain","title":"Particle Rain \u7c92\u5b50\u96e8","text":"<p>\u8ba9\u539f\u7248\u7684\u96e8\u66f4\u597d\u770b</p> <p></p>"},{"location":"preparation/#idwtialsimmoedm","title":"idwtialsimmoedm \u9644\u9b54\u7b80\u4ecb","text":"<p>\u5b89\u88c5\u540e\u53ef\u4ee5\u663e\u793a\u670d\u52a1\u5668\u66f4\u591a\u9644\u9b54\u7684\u9644\u9b54\u7b80\u4ecb, \u4e0d\u7528\u7ecf\u5e38\u67e5wiki</p> <p>\u9700\u8981\u624b\u52a8\u914d\u7f6e</p> <p></p>"},{"location":"preparation/#paginated-advancements","title":"Paginated Advancements \u5206\u9875\u8fdb\u5ea6","text":"<p>\u4e0d\u7528\u5bf9\u7740\u539f\u7248\u5c0f\u7684\u53ef\u601c\u7684\u6210\u5c31\u5c4f\u5e55\u53d1\u5446\u4e86</p>"},{"location":"preparation/#4","title":"4. \u767b\u5f55\u65b9\u5f0f","text":"\u5185\u670d\u5916\u670d <ul> <li> <p> \u6b63\u7248\u767b\u5f55</p> <p>\u975e\u5e38\u7b80\u5355, \u4f7f\u7528\u6b63\u7248\u8d26\u53f7\u8fdb\u5165\u670d\u52a1\u5668\u5373\u53ef</p> </li> <li> <p> LittleSkin\u76ae\u80a4\u7ad9\u767b\u5f55</p> <p>\u6ce8\u518c\u597d\u8d26\u53f7\u540e \u4f60\u9700\u8981\u5728\u542f\u52a8\u5668\u5c06\u5176\u8bbe\u7f6e\u4e3a\u767b\u5f55\u65b9\u5f0f \u53ef\u81ea\u884c\u641c\u7d22\u5176\u4ed6\u6559\u7a0b</p> <p> \u67e5\u770b\u6559\u7a0b</p> </li> </ul> <ul> <li> <p> \u6b63\u7248\u767b\u5f55</p> <p>\u975e\u5e38\u7b80\u5355, \u4f7f\u7528\u6b63\u7248\u8d26\u53f7\u8fdb\u5165\u670d\u52a1\u5668\u5373\u53ef.</p> </li> <li> <p>\u79bb\u7ebf\u767b\u5f55</p> <p>\u5bf9\u4e8e\u65e0\u6b63\u7248\u73a9\u5bb6, \u8bf7\u59cb\u7ec8\u8003\u8651\u8d2d\u5165\u6b63\u7248 \u8fd9\u91cc\u5c31\u4e0d\u591a\u8bf4\u4e86, \u8981\u6ce8\u610f\u7684\u53ea\u6709\u4e24\u70b9 1. \u8bb0\u4f4f\u81ea\u5df1\u7684\u8d26\u53f7\u540d! 2. \u8bbe\u7f6e\u5f3a\u5bc6\u7801!</p> </li> </ul> \u767b\u5f55\u65b9\u5f0f \u4f18\u7f3a\u70b9 \u9002\u7528\u8303\u56f4 \u6b63\u7248\u767b\u5f55 \u65e0 \u5168\u90e8 LittleSkin\u76ae\u80a4\u7ad9\u767b\u5f55 \u53ef\u80fd\u4f1a\u91cd\u540d \u5185\u670d \u79bb\u7ebf\u767b\u5f55 \u53ef\u80fd\u4f1a\u91cd\u540d, \u5b89\u5168\u6027\u4f4e \u5916\u670d <p>\u5404\u767b\u5f55\u65b9\u5f0f\u4f18\u7f3a\u70b9\u53ca\u9002\u7528\u8303\u56f4</p>"},{"location":"preparation/#5","title":"5. \u8fdb\u5165\u670d\u52a1\u5668","text":"<ol> <li>\u5728\u7fa4\u516c\u544a\u83b7\u53d6\u6700\u65b0\u7684\u670d\u52a1\u5668IP</li> <li>\u6253\u5f00\"\u591a\u4eba\u6e38\u620f\"\u9875\u9762</li> <li>\u70b9\u51fb\"\u6dfb\u52a0\u670d\u52a1\u5668\"</li> <li>\u5c06\u60a8\u83b7\u53d6\u5230\u7684IP\u586b\u5165\"\u670d\u52a1\u5668\u5730\u5740\"</li> <li>\u70b9\u51fb\"\u5b8c\u6210\"</li> <li>\ud83c\udfae\u4eab\u53d7\u6e38\u620f\u5427\ud83c\udfae</li> </ol> IPv4\u4e0eIPv6 <p>\u4e0d\u77e5\u9053\u7684\u70b9\u8fd9\u91cc \u68c0\u67e5\u60a8\u7684\u8bbe\u5907\u662f\u5426\u540c\u65f6\u652f\u6301 IPv4 \u548c IPv6, \u4ee5\u53ca\u662f\u5426\u6b63\u786e\u914d\u7f6e\u4e86 IPv6 \u5730\u5740 \u8d85\u7ea7\u7b80\u5355\u7684\u529e\u6cd5: \u8bbf\u95eehttps://ipw.cn/ </p>"},{"location":"preparation/#_1","title":"\u9009\u62e9\u7ebf\u8def","text":"\u6d4b\u8bd5\u7ed3\u679c \u7ebf\u8def\u9009\u62e9 IPv4\u4e00\u680f\u6709\u5185\u5bb9 \u9009\u62e9IPv4\u7ebf\u8def IPv6\u4e00\u680f\u6709\u5185\u5bb9 \u9009\u62e9IPv6\u7ebf\u8def \u90fd\u6709\u5185\u5bb9 \u9009\u62e9IPv6\u7ebf\u8def \u90fd\u6ca1\u6709\u5185\u5bb9 \u7f51\u7ad9\u548c\u4f60\u6709\u4e00\u4e2a\u51faBug\u4e86"},{"location":"preparation/#why-ipv6","title":"Why IPv6","text":"<p>IPv6\u53ef\u4ee5\u76f4\u8fde\u670d\u52a1\u5668, \u83b7\u5f97\u6700\u4f4e\u7684\u5ef6\u8fdf</p> <p>IPv4\u9700\u8981\u8d70\u5185\u7f51\u7a7f\u900f, \u5ef6\u8fdf\u53ef\u80fd\u4f1a\u4e0d\u7406\u60f3</p>"},{"location":"preparation/#6","title":"6. \u6392\u67e5\u6545\u969c","text":"<p>\u5982\u679c\u5f88\u4e0d\u5e78, \u60a8\u7684\u5ba2\u6237\u7aef\u53d1\u751f\u4e86\u6545\u969c, \u8bf7\u79fb\u6b65\u5e38\u89c1\u95ee\u9898\u89e3\u7b54</p>"},{"location":"preparation/#_2","title":"\u66f4\u591a\u4fe1\u606f","text":"<p>\u5982\u679c\u4f60\u8fd8\u60f3\u4e86\u89e3\u66f4\u591a\u4fe1\u606f, \u8bf7\u67e5\u770b\u4e0b\u4e00\u7bc7\u6587\u6863.</p>"},{"location":"preparation/#_3","title":"\u5927\u529f\u544a\u6210!","text":"<p>\u5982\u679c\u4f60\u5df2\u7ecf\u7b49\u4e0d\u53ca\u4e86:</p> <ul> <li> <p>\u5185\u670d\u6587\u6863     \u4f60\u9700\u8981\u77e5\u9053\u7684\u4e00\u5207\u90fd\u5728\u8fd9\u91cc</p> </li> <li> <p>\u5916\u670d\u6587\u6863     \u5916\u670d\u4f7f\u7528\u624b\u518c</p> </li> </ul>"},{"location":"rules/","title":"\u670d\u89c4","text":"<p>\u8054\u5408\u5c01\u7981</p> <p>\u5c01\u7981/\u7981\u8a00\u60e9\u7f5a\u4f1a\u540c\u6b65\u5230TACS\u6240\u6709\u670d\u52a1\u5668</p>"},{"location":"rules/#_1","title":"\u5efa\u8bae\u9605\u8bfb","text":"<p>\u4e2d\u6587 Minecraft Wiki \u6559\u7a0b:\u4e0d\u8be5\u505a\u7684\u4e8b</p>"},{"location":"rules/#_2","title":"\u975e\u6b63\u5e38\u5ba2\u6237\u7aef","text":"<p>\u670d\u52a1\u5668\u7981\u6b62\u4e00\u5207Velocity\u5957\u670d\u52a1\u5668, Geyser Standalone\u5957\u670d\u52a1\u5668, ViaProxy\u5957\u670d\u52a1\u5668, PCRC\u5957\u670d\u52a1\u5668, \u5404\u79cd\u4ee3\u7406\u5957\u670d\u52a1\u5668\u7b49\u884c\u4e3a</p> <p>\u53d1\u73b0\u5373BanIP\u6bb5\u53ca\u6e38\u620f\u5185Ban</p>"},{"location":"rules/#_3","title":"\u5f00\u6302\u8005/\u9ed1\u5ba2/\u653b\u51fb\u8005","text":"<p>\u5728TACS\u4e2d, \u5bf9\u5f00\u6302\u8005/\u9ed1\u5ba2\u7684\u5b9a\u4e49\u5982\u4e0b</p> <ul> <li>\u672a\u4f7f\u7528\u751f\u7535\u7c7b(masa\u5168\u5bb6\u6876)\u6a21\u7ec4\u5b9e\u73b0\u975e\u6b63\u5e38\u6e38\u620f\u884c\u4e3a(\u6740\u622e\u5149\u73af, \u81ea\u52a8\u642d\u8def)</li> <li>\u672a\u4f7f\u7528\u670d\u52a1\u5668\u63d0\u4f9b\u7684\u65b9\u5f0f\u5b9e\u73b0\u975e\u6b63\u5e38\u6e38\u620f\u884c\u4e3a(\u6740\u622e\u5149\u73af, \u81ea\u52a8\u642d\u8def)</li> <li>\u4f7f\u7528wurst/meteor\u7b49\u5916\u6302\u5ba2\u6237\u7aef\u5165\u670d\u7684(\u65e0\u8bba\u662f\u5426\u542f\u7528\u5ba2\u6237\u7aef\u5185\u529f\u80fd)</li> <li>\u5c1d\u8bd5\u76d7\u53d6\u4ed6\u4eba\u8d26\u53f7\u7684</li> <li>\u5c1d\u8bd5\u7206\u7834\u670d\u52a1\u5668\u540e\u53f0\u548c\u7ba1\u7406\u7f51\u9875\u7684</li> <li>\u5c1d\u8bd5\u7834\u574f\u670d\u52a1\u5668\u5185\u73a9\u5bb6\u7cfb\u7edf\u7684</li> <li>\u5c1d\u8bd5DDOS\u670d\u52a1\u5668\u7684</li> <li>\u5c1d\u8bd5\u653b\u51fb\u670d\u52a1\u5668\u7f51\u7ad9\u7684</li> <li>\u5bf9\u670d\u52a1\u5668\u8fdb\u884c\u5361\u670d, \u5bfc\u81f4\u4ed6\u4eba\u4e0d\u80fd\u6b63\u5e38\u6e38\u73a9\u7684</li> </ul> <p>\u4ee5\u4e0a\u884c\u4e3a\u53ea\u8981\u5f00\u59cb, \u5c31\u89c6\u4e3a\u89e6\u72af</p>"},{"location":"rules/#_4","title":"\u5077\u76d7\u8005","text":"<p>\u672c\u6761\u4ec5\u53d7\u5bb3\u8005\u5411\u7ba1\u7406\u62a5\u544a\u540e, \u624d\u5904\u7406</p> <p>\u5728TACS\u4e2d, \u5bf9\u5077\u76d7\u8005\u7684\u5b9a\u4e49\u5982\u4e0b</p> <ul> <li>\u5077\u53d6\u4ed6\u4eba\u8d22\u4ea7\u7684</li> <li>\u5077\u53d6\u516c\u5171\u673a\u5668\u5185\u586b\u5145\u7269\u7b49\u91cd\u8981\u5143\u4ef6\u7684</li> </ul> <p>\u4ed6\u4eba\u7269\u54c1\u6307\u73a9\u5bb6\u7684\u4e00\u5207\u4e2a\u4eba\u8d44\u4ea7, \u5305\u62ec\u4f46\u4e0d\u9650\u4e8e\u7269\u54c1, \u623f\u5c4b, \u673a\u5668, \u5ba0\u7269, \u4f5c\u7269</p>"},{"location":"rules/#_5","title":"\u6076\u610f\u7834\u574f\u8005","text":"<p>\u672c\u6761\u4ec5\u53d7\u5bb3\u8005\u5411\u7ba1\u7406\u62a5\u544a\u540e, \u624d\u5904\u7406</p> <ul> <li>\u7834\u574f\u670d\u52a1\u5668\u5185\u57fa\u7840\u8bbe\u65bd\u7684</li> <li>\u7834\u574f\u670d\u52a1\u5668\u5185\u4ea4\u901a\u8bbe\u65bd\u7684</li> <li>\u901a\u8fc7\u76f4\u63a5/\u95f4\u63a5\u65b9\u5f0f\u7834\u574f\u4ed6\u4eba\u673a\u5668\u7684</li> <li>\u6076\u610f\u7834\u574f\u670d\u52a1\u5668\u672a\u5f00\u53d1\u5730\u5f62\u7684</li> <li>\u6076\u610f\u7834\u574f\u670d\u52a1\u5668\u5185\u4ed6\u4eba\u5730\u72f1\u95e8\u7684</li> </ul>"},{"location":"rules/#_6","title":"\u8a00\u8bba\u4e0d\u5f53\u8005/\u5237\u5c4f\u8005","text":"<ul> <li>\u5728\u6e38\u620f\u5185\u5236\u9020\u5927\u91cf\u6d88\u606f\u5237\u5c4f\u7684</li> <li>\u5728\u670d\u52a1\u5668\u8bed\u97f3\u9891\u9053\u5185\u53d1\u8868\u4e0d\u5f53\u8a00\u8bba\u7684</li> <li>\u5728\u670d\u52a1\u5668\u7fa4\u5185\u53d1\u8868\u4e0d\u5f53\u8a00\u8bba\u7684</li> <li>\u5728\u670d\u52a1\u5668\u6e38\u620f\u5185\u5185\u53d1\u8868\u4e0d\u5f53\u8a00\u8bba\u7684</li> <li>\u5728\u7fa4\u5185\u5927\u91cf\u53d1\u9001\u6d88\u606f\u5237\u5c4f\u7684</li> <li>\u5229\u7528\u7fa4\u5185\u673a\u5668\u4eba\u5237\u5c4f\u7684\u7684</li> </ul> <p>\u4e0d\u5f53\u8a00\u8bba\u6307\u8fdd\u53cd\u4e2d\u56fd\u6cd5\u5f8b\u7684\u8a00\u8bba\u6216\u8086\u610f\u8a00\u8bed\u653b\u51fb, \u8c29\u9a82\u4ed6\u4eba\u7684\u8a00\u8bba</p>"},{"location":"rules/#_7","title":"\u8fdd\u53cd\u516c\u5e8f\u826f\u4fd7\u8005","text":"<p>\u767e\u5ea6\u767e\u79d1</p>"},{"location":"rules/#_8","title":"\u5904\u7f5a","text":"<p>\u57fa\u672c\u5904\u7f5a\u6709\u56db\u7c7b:</p> <ul> <li>\u7981\u8a00</li> <li>\u4e34\u65f6\u5c01\u7981</li> <li>\u6c38\u4e45\u5c01\u7981</li> <li>NDP\u8054\u5408\u5c01\u7981</li> </ul> <p>\u6240\u6709\u5904\u7f5a\u90fd\u4f1a\u5728\u7fa4\u516c\u544a\u5185\u516c\u793a</p> <p>\u4ee5\u4e0a\u884c\u4e3a\u4e2d</p> <ul> <li>\u7a0b\u5ea6\u8f83\u8f7b\u8005\u914c\u60c5\u5c01\u79811~30\u5929</li> <li>\u7a0b\u5ea6\u4e25\u91cd\u8005\u6c38\u4e45\u5c01\u7981/FDP\u8054\u5408\u5c01\u7981</li> </ul> <p>\u4f8b\u5916:</p> <ul> <li>\"\u8a00\u8bba\u4e0d\u5f53\u8005/\u5237\u5c4f\u8005\"\u8f83\u8f7b\u7684, \u7fa4\u5185\u548c\u6e38\u620f\u5185\u7981\u8a001~7\u5929</li> <li>\"\u5f00\u6302\u8005/\u9ed1\u5ba2/\u653b\u51fb\u8005\"\u9664\u975e\u5e38\u8f7b\u5fae\u5916, \u5176\u4f59\u5747\u6c38\u4e45\u5c01\u7981</li> </ul>"},{"location":"rules/#_9","title":"\u8865\u5145\u8bf4\u660e","text":""},{"location":"rules/#_10","title":"\u5bf9\u7ecf\u5178\u8a00\u8bba\u7684\u7edf\u4e00\u56de\u590d","text":""},{"location":"rules/#_11","title":"\u4e0d\u662f\u6211\u73a9\u7684, \u662f\u6211\u4eb2\u621a\u73a9\u7684","text":"<p>\u4f60\u5e76\u672a\u4fdd\u7ba1\u597d\u8d26\u53f7, \u5c5e\u4e8e\u4f60\u5355\u65b9\u9762\u7684\u8fc7\u9519.</p>"},{"location":"rules/#xxx","title":"xxx\u4e5f\u6709, \u4e3a\u4ec0\u4e48\u4e0d\u5904\u7f5a\u4ed6","text":"<p>\u8fd9\u5e76\u4e0d\u4ee3\u8868\u4f60\u6ca1\u6709\u8fc7\u9519, \u53cd\u800c\u662f\u4f60\u9003\u907f\u8d23\u4efb\u7684\u4e00\u79cd\u8868\u73b0.</p>"},{"location":"sponsors/","title":"\u8d5e\u52a9","text":"<p>\u60a8\u7684\u652f\u6301\u662f\u6211\u4eec\u575a\u6301\u4e0b\u53bb\u7684\u6700\u5927\u52a8\u529b</p>"},{"location":"sponsors/#night_and_light","title":"Night_and_Light","text":"<ul> <li>\u670d\u52a1\u5668\u65e9\u671f\u6240\u4f7f\u7528\u7684 13600KF \u7684 VPS \u4e91\u670d\u52a1\u5668</li> <li>14900K \u7684 VPS \u4e91\u670d\u52a1\u5668</li> </ul>"},{"location":"sponsors/#gotoueijirou","title":"Gotoueijirou","text":"<ul> <li>\u63d0\u4f9b\u7269\u7406\u673a\u673a\u623f</li> <li>Sakura FRP \u8d26\u53f7</li> </ul>"},{"location":"sponsors/#zzfx1166","title":"zzfx1166","text":"<ul> <li>1000 \u5143\uff08\u652f\u4e